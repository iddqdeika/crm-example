# PostgreSQL (used by backend and docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=qualityboard

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/qualityboard
SECRET_KEY=change-me-in-production-min-32-chars
APP_ENV=development

# MinIO / Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
STORAGE_ENDPOINT_URL=http://minio:9000
STORAGE_PUBLIC_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=qualityboard-media

# Redis
REDIS_URL=redis://localhost:6379

# Session timeouts
SESSION_INACTIVITY_TIMEOUT=1800
SESSION_MAX_LIFETIME=28800
SESSION_WARNING_SECONDS=300
