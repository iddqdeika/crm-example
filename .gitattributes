# Default: normalize to LF in the repo, check out as-is on all platforms
* text=auto eol=lf

# Shell scripts must always be LF — CRLF breaks shebangs in Linux containers
*.sh text eol=lf

# Docker / config files — keep LF
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
nginx.conf text eol=lf

# Source code — normalize
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.mdc text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env* text eol=lf

# Binary files — do not touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
